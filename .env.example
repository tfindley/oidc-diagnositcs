# ── OIDC Provider ─────────────────────────────────────────────────────────────
# Keycloak: http://<host>:8080/realms/<realm>/.well-known/openid-configuration
OIDC_DISCOVERY_URL=http://localhost:8080/realms/master/.well-known/openid-configuration

# Client credentials — create a "confidential" client in Keycloak
OIDC_CLIENT_ID=oidc-diagnostic-client
OIDC_CLIENT_SECRET=your-client-secret-here

# Scopes to request (space-separated); add any custom scopes your realm exposes
OIDC_SCOPE=openid email profile roles

# PKCE code challenge method — S256 (default, required by Kanidm), plain, or disabled
# Disable only for legacy providers that do not support PKCE.
OIDC_PKCE_METHOD=S256

# Token signing algorithm to enforce — ES256 (recommended) or RS256 (legacy).
# Leave unset to accept whatever algorithm the server advertises (safe default).
OIDC_TOKEN_SIGNING_ALG=ES256

# ── Flask ──────────────────────────────────────────────────────────────────────
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_DEBUG=false
PORT=5000

# ── Reverse proxy (Traefik, nginx, etc.) ──────────────────────────────────────
# When running behind a TLS-terminating proxy the app auto-detects https via the
# X-Forwarded-Proto header — no extra config needed. If your proxy doesn't forward
# that header, set this to force https in generated callback URLs.
# PREFERRED_URL_SCHEME=https
