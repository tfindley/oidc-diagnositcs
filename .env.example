# ── OIDC Provider ─────────────────────────────────────────────────────────────
# Keycloak: http://<host>:8080/realms/<realm>/.well-known/openid-configuration
OIDC_DISCOVERY_URL=http://localhost:8080/realms/master/.well-known/openid-configuration

# Client credentials — create a "confidential" client in Keycloak
OIDC_CLIENT_ID=oidc-diagnostic-client
OIDC_CLIENT_SECRET=your-client-secret-here

# Scopes to request (space-separated); add any custom scopes your realm exposes
OIDC_SCOPE=openid email profile roles

# ── Flask ──────────────────────────────────────────────────────────────────────
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_DEBUG=false
PORT=5000
